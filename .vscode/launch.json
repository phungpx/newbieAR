{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Synthesis",
            "type": "debugpy",
            "request": "launch",
            "module": "src.synthesis.synthesize",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--file_dir",
                "data/wikipedia/files",
                "--output_dir",
                "data/goldens/wikipedia",
            ]
        },
        {
            "name": "Ingestion",
            "type": "debugpy",
            "request": "launch",
            "module": "src.rags.graph_rag.ingest_documents",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--file_dir",
                "data/wikipedia/documents",
                "--output_dir",
                "data/wikipedia/chunks",
            ]
        },
        {
            "name": "Evaluation",
            "type": "debugpy",
            "request": "launch",
            "module": "src.evals.evaluate",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--file_dir",
                "./data/goldens/Isaac_Newton",
                "--retrieval_window_size",
                "10",
                "--collection_name",
                "wikipedia",
                "--force_rerun"
            ]
        },
        {
            "name": "Retrieval",
            "type": "debugpy",
            "request": "launch",
            "module": "src.retrieval.graph_rag",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--query",
                "What is the capital of France?",
                "--num_results",
                "10",
            ]
        }
    ]
}
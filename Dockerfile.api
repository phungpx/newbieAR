FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Install dependencies (no dev/test extras)
COPY pyproject.toml uv.lock ./
RUN uv sync --no-dev

# Copy application source
COPY src/ src/

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "src.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
